{
  "name": "ghostsignals",
  "version": "0.1.0",
  "description": "Prediction markets for hedging, not gambling. Replace fiat currency with personalized risk baskets.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.16.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "prediction-markets",
    "hedging",
    "finance",
    "typescript",
    "blockchain",
    "defi",
    "ghostvector"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flaukowski/ghostsignals.git"
  }
}