{
  "name": "@ghostsignals/contracts",
  "version": "0.1.0",
  "description": "Solidity smart contracts for prediction markets and hedging",
  "type": "module",
  "files": [
    "artifacts",
    "contracts",
    "typechain-types"
  ],
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat deploy --network localhost",
    "deploy:testnet": "hardhat deploy --network sepolia",
    "lint": "solhint 'contracts/**/*.sol'",
    "clean": "hardhat clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.2",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@typechain/hardhat": "^6.1.6",
    "hardhat": "^2.17.1",
    "hardhat-deploy": "^0.11.34",
    "solhint": "^3.6.2",
    "ethers": "^5.7.2"
  }
}