    "clean": "hardhat clean"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/hardhat": "^9.0.0",
    "hardhat": "^2.22.0",
    "hardhat-deploy": "^0.12.0",
    "solhint": "^5.0.0",
    "ethers": "^6.0.0"
  }
}