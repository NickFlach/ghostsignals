{
  "name": "@ghostsignals/contracts",
  "version": "0.1.0",
  "description": "Solidity smart contracts for prediction markets and hedging",
  "type": "module",
  "files": [
    "artifacts",
    "contracts",
    "typechain-types"
  ],
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat deploy --network localhost",
